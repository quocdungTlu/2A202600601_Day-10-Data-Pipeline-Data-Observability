# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: openai | anthropic | gemini | openrouter | ollama | custom
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# ── API Keys (fill in only the provider you selected above) ──────────────────
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Provider Base URLs (optional, defaults shown) ────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434

# ── Custom OpenAI-compatible endpoint (set LLM_PROVIDER=custom to use) ───────
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=

# ── Pipeline flags (optional) ────────────────────────────────────────────────
# Set to 1 to force re-fetch from Crossref API (otherwise uses cached raw data)
# REFRESH_SOURCE=0
# Set to 1 to rebuild the evaluation test set from scratch
# REFRESH_TEST_SET=0
# Set to 1 to run the slower RAGAS evaluation pass (requires ragas package)
# RUN_RAGAS=0
